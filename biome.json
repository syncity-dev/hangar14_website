{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "files": {
    "includes": [
      "*.html",
      "qr.html",
      "assets/css/style.css",
      "assets/css/b2b-page.css",
      "assets/css/boarding-page.css",
      "assets/css/boarding-pages.css",
      "assets/css/gabrijela-page.css",
      "assets/css/index-page.css",
      "assets/css/qr-page.css",
      "assets/js/scripts.js"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "html": {
    "formatter": {
      "enabled": true
    }
  },
  "css": {
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": false
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": false
  }
}
